# ── Space — environment configuration ──────────────────────────────────────
# Copy this file to .env and fill in values as needed.
# All variables are optional; defaults produce a working local setup.

# ── AIS vessel data ────────────────────────────────────────────────────────
# Set this to enable live maritime vessel tracking via aisstream.io.
# Without it, the app falls back to 20 demo vessels on real shipping lanes.
# Get a free key at https://aisstream.io
AISSTREAM_API_KEY=

# ── Flight bounding box ────────────────────────────────────────────────────
# Lat/lon box for OpenSky ADS-B flight data (defaults: Ontario, Canada).
# Adjust to your region for more relevant local air traffic.
FLIGHTS_LAMIN=43.5
FLIGHTS_LOMIN=-80.0
FLIGHTS_LAMAX=45.5
FLIGHTS_LOMAX=-76.0

# ── Google Maps 3D Tiles ───────────────────────────────────────────────────
# Set in static/index.html (line ~749) to enable photorealistic 3D city models.
# Not an env var — paste your key directly into the Maps_API_KEY constant.
# GOOGLE_MAPS_API_KEY=YOUR_KEY_HERE
